{
    "name": "@eka-care/apollo-assist",
    "private": false,
    "version": "0.1.43",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:stage": "yarn version --prerelease --preid=dev && vite build --mode stage",
        "build:prod": "yarn version --patch && vite build --mode prod",
        "build:prod:patch": "yarn version --patch &&  vite build --mode prod",
        "build:prod:minor": "yarn version --minor &&  vite build --mode prod",
        "build:prod:major": "yarn version --major &&  vite build --mode prod",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "files": [
        "dist/widget-loader.js",
        "dist/widget.js",
        "dist/assets/*",
        "README.md"
    ],
    "keywords": [
        "eka-care",
        "apollo-assist",
        "medical-assistant",
        "chatbot",
        "chat-widget"
    ],
    "author": "Geethanjali S",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eka-care/eka-med-assist-web.git"
    },
    "homepage": "https://github.com/eka-care/eka-med-assist-web/blob/main/README.md",
    "dependencies": {
        "@radix-ui/react-slot": "^1.2.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jszip": "^3.10.1",
        "lucide-react": "^0.536.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.3.1",
        "uuid": "^13.0.0",
        "zustand": "^5.0.7"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.1",
        "@tailwindcss/vite": "^4.1.11",
        "@types/node": "^24.2.1",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.6.0",
        "eslint": "^9.30.1",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.3.0",
        "terser": "^5.44.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.35.1",
        "vite": "^7.0.4"
    },
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/widget-loader.js",
    "resolutions": {
        "typescript": "^5.9.2"
    }
}
